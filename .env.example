# Cortivium MCP Server Configuration
# Copy to .env and customize

# Server
CORTIVIUM_HOST=0.0.0.0
CORTIVIUM_PORT=8080
CORTIVIUM_SERVER_NAME=cortivium
CORTIVIUM_SERVER_VERSION=1.0.0

# Security - auto-generated on first run if empty
CORTIVIUM_SECRET_KEY=

# Database (SQLite) - relative to project root
CORTIVIUM_DATABASE_PATH=storage/cortivium.db

# Storage - runtime data directory
CORTIVIUM_STORAGE_PATH=storage

# Logging
CORTIVIUM_LOG_LEVEL=info

# SSL/TLS (leave empty for HTTP)
CORTIVIUM_SSL_CERT=
CORTIVIUM_SSL_KEY=

# Ghost Skills plugin (enabled by default)
# No additional configuration needed
